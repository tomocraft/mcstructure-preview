{
  "name": "mcstructure-preview",
  "displayName": "MCStructure Preview",
  "description": "Preview Minecraft Bedrock .mcstructure files as an interactive 3D scene.",
  "version": "1.1.0",
  "publisher": "Tomocraft",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:mcstructure.preview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tomocraft/mcstructure-preview.git"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mcstructure.preview",
        "displayName": "MCStructure 3D Preview",
        "selector": [
          {
            "filenamePattern": "*.mcstructure"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./ && npm run build:view",
    "watch": "concurrently \"tsc -watch -p ./\" \"npm run watch:view\"",
    "vscode:prepublish": "npm run compile",
    "lint": "echo lint not configured",
    "test": "echo \"No tests configured\"",
    "build": "node scripts/build-viewer.mjs",
    "build:view": "node scripts/build-viewer.mjs",
    "watch:view": "node scripts/build-viewer.mjs --watch"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "minecraft-assets": "github:tomocraft/node-minecraft-assets#f671313e8bf186bd40d002837c75b48a145fb88c",
    "prismarine-nbt": "^2.8.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "@types/vscode": "^1.90.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
